# ─── MEMBER APP (Expo uses EXPO_PUBLIC_ prefix) ──────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# Feature-level mock flags — set to true while backend is still building
EXPO_PUBLIC_MOCK_AUTH=true
EXPO_PUBLIC_MOCK_SACCOS=true
EXPO_PUBLIC_MOCK_MEMBERSHIPS=true
EXPO_PUBLIC_MOCK_LOANS=true
EXPO_PUBLIC_MOCK_PAYMENTS=true

# Firebase (push notifications) — leave empty until FCM is configured
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# ─── SACCO ADMIN PORTAL (Vite uses VITE_ prefix) ─────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_MOCK_SACCO_ADMIN=true

# ─── SUPER ADMIN PORTAL ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_MOCK_SUPER_ADMIN=true
